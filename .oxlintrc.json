{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "eslint", "oxc"],
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "restriction": "error",
    "perf": "warn",
    "style": "warn",
    "pedantic": "off",
    "nursery": "off"
  },
  "env": {
    "builtin": true
  },

  "rules": {},
  "overrides": [
    {
      // This project's suite uses Playwright's `*.spec.ts` convention (not
      // `*.test.ts`); both globs are kept so the intent is explicit either way.
      "files": ["**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "init-declarations": "off",
        "typescript/no-floating-promises": "off",
        "typescript/no-unsafe-type-assertion": "off",
        // Test fixture values (counters, stored payloads) are self-explanatory
        // from the surrounding `test(...)` name; naming a constant for each one
        // would add indirection without adding clarity.
        "no-magic-numbers": "off",
        // `__spaMarker` is a deliberately double-underscore-prefixed marker
        // stashed on `window` inside page.evaluate(), mirroring the
        // `__something__` convention used by tools like `__coverage__` to
        // avoid colliding with real app globals.
        "no-underscore-dangle": ["error", { "allow": ["__spaMarker"] }],
        // Playwright's `test(...)` callbacks and its locator/assertion APIs
        // (page.goto, expect(...).toBeVisible, page.evaluate, ...) are
        // Promise-based; the suite cannot avoid `async`/`await` without
        // reverting to manual `.then()` chains for every action.
        "oxc/no-async-await": "off"
      }
    },
    {
      "files": ["playwright.config.ts"],
      "rules": {
        // Playwright's own docs recommend `{ ...devices["Desktop Chrome"] }` to
        // compose project configs; `Object.assign` would fight the ecosystem
        // convention for no readability gain.
        "oxc/no-rest-spread-properties": "off",
        // `resolveWorkers` returns `number | undefined` (Playwright's own type
        // for "no override"). `consistent-return` requires the `undefined`
        // path to `return` explicitly once another path returns a value, which
        // `no-undefined` then bans writing literally — the two rules can't
        // both be satisfied here, so this one loses.
        "no-undefined": "off"
      }
    }
  ]
}
